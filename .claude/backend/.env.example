# AI Career Guidance Platform - Backend Configuration

# Database Connection (e.g. postgresql://user:pass@host:5432/db)
DATABASE_URL=sqlite:///./career_platform.db

# JWT Security
SECRET_KEY=generate-a-secure-random-key-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Provider
GROQ_API_KEY=your_groq_api_key_here

# Deployment Environment (development / production)
APP_ENV=production

# CORS Allowed Origins (Comma separated strings)
# e.g. ALLOWED_ORIGINS=["https://your-app.vercel.app", "http://localhost:3000"]
ALLOWED_ORIGINS=["*"]
