# All required environment variables — copy this file to .env and fill in values
# Never commit the real .env to version control!

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./career_platform.db
# For MySQL: mysql://user:password@host:3306/dbname

# ── JWT (REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(64))")
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI API Keys ───────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_KEY

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE.apps.googleusercontent.com

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Environment ───────────────────────────────────────────────────────────────
APP_ENV=development
